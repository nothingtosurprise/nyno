{
  "name": "proj40",
  "version": "1.0.0",
  "description": "Simple React SSR with Vite and Express",
  "type": "module",
  "bin": {
    "nyno": "./cli/cli.js"
  },
  "scripts": {
    "build:node": "node scripts/init-private-folder.js && node scripts/init-input-folder.js && node scripts/copy-private-extensions.js && node scripts/loadExtensions.js",
    "dev": "node server-dev.js",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.jsx --outDir dist/server",
    "build": "npm run build:client && npm run build:server",
    "serve": "node server-prod.js"
  },
  "dependencies": {
    "@msgpack/msgpack": "3.1.3",
    "express": "5.1.0",
    "glob": "13.0.6",
    "markdown-it": "14.1.0",
    "pg": "8.20.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.1",
    "reactflow": "11.11.4",
    "remark-gfm": "4.0.1",
    "ssh2": "1.17.0",
    "fluent-ffmpeg": "2.1.3",
"ffmpeg-static": "5.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "js-yaml": "4.1.1",
    "vite": "7.3.6"
  }
}
